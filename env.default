# Experiment configuration
EXPERIMENT_NAME = "ait_llama32_ex"
PARSER_TYPE = "main"
EXAMPLES_RETRIEVAL = 1
CORRECTION_STEPS = 3
GENERATED_GRAPHS_RETRIEVAL = 0
PROMPT_PATH = "./resources/prompts/main.system.md"
# PROMPT_PATH = "./resources/prompts/baseline.system.md"
EXAMPLES_PATH = "./resources/data/ait/train.ttl"
# EXAMPLES_PATH = "./resources/data/polito/train.ttl"
TESTS_PATH = "./resources/data/ait/test.ttl"
# TESTS_PATH = "./resources/data/polito/test.ttl"

# Backend configuration
PARSER_BACKEND = "vllm"
EMBEDDINGS_BACKEND = "infinity"
NEO4J_URL = "bolt+ssc://localhost:7687"
VLLM_ADDITIONAL_ARGS = "--dtype=bfloat16 --tensor-parallel-size 2 --max-model-len 4096 --swap-space 8 --quantization awq --tool-call-parser hermes --chat-template examples/tool_chat_template_hermes.jinja" 
VLLM_CUDA_VISIBLE_DEVICES =

# Models configuration
PARSER_MODEL = "meta-llama/Llama-3.2-3B-Instruct" # VLLM/HF
# PARSER_MODEL = "us.meta.llama3-3-70b-instruct-v1:0" # Bedrock
EMBEDDINGS_MODEL = "Alibaba-NLP/gte-multilingual-base" # Infinity/HF
# EMBEDDINGS_MODEL = "nomic-embed-text" # Ollama
TESTS_MODEL = "meta-llama/Llama-3.2-3B-Instruct" # VLLM/HF
# TESTS_MODEL = "us.anthropic.claude-3-7-sonnet-20250219-v1:0" # Bedrock
#PROMPT_PATH = "./resources/prompts/baseline.system.md"

# Access tokens
HF_TOKEN =
AWS_ACCESS_KEY_ID =
AWS_SECRET_ACCESS_KEY =
AWS_ROLE_ARN =