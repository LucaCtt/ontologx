@base <https://cyberseclab.unibs.it/mlsx/dict>.
@prefix : <https://cyberseclab.unibs.it/mlsx/dict#>.
@prefix olx: <https://cyberseclab.unibs.it/olx/dict#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix mls: <http://www.w3.org/ns/mls#>.

<https://cyberseclab.unibs.it/mlsx/dict> rdf:type owl:Ontology;
  owl:versionIRI <https://cyberseclab.unibs.it/mlsx/dict/1.0.0>;
  <http://purl.org/dc/elements/1.1/creator> "Luca Cotti";
  <http://purl.org/dc/elements/1.1/description> "An ontology to represent a dataset of log events.";
  <http://purl.org/dc/elements/1.1/rights> "http://creativecommons.org/licenses/by/4.0/";
  <http://purl.org/dc/elements/1.1/title> "The OntoLogX log event dataset ontology.";
  <http://purl.org/dc/elements/1.1/language> "English";
  <http://purl.org/vocab/vann/preferredNamespacePrefix> "mlsx".

#################################################################
#    Annotation properties
#################################################################
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty.

<http://purl.org/dc/elements/1.1/description> rdf:type owl:AnnotationProperty.
<http://purl.org/dc/elements/1.1/rights> rdf:type owl:AnnotationProperty.
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty.
<http://purl.org/dc/elements/1.1/language> rdf:type owl:AnnotationProperty.
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty.


#################################################################
#    Classes
#################################################################
:Study rdf:type owl:Class;
  owl:equivalentClass mls:Study;
  rdfs:label "Study";
  rdfs:comment "A study that uses a log event dataset to train or evaluate models.".

:Experiment rdf:type owl:Class;
  owl:equivalentClass mls:Experiment;
  rdfs:label "Experiment";
  rdfs:comment "An experiment that uses a log event dataset to train or evaluate models.".

:Run rdf:type owl:Class;
  owl:equivalentClass mls:Run;
  rdfs:label "Run";
  rdfs:comment "A run of a log event dataset, which can be used to train or evaluate models.".

:HyperParameter rdf:type owl:Class;
  owl:equivalentClass mls:HyperParameter;
  rdfs:label "HyperParameter";
  rdfs:comment "A hyperparameter used in the training of models with log event datasets.".

:HyperParameterSetting rdf:type owl:Class;
  owl:equivalentClass mls:HyperParameterSetting;
  rdfs:label "HyperParameterSetting";
  rdfs:comment "A setting for a hyperparameter in the context of a log event dataset.".

:EvaluationMeasure rdf:type owl:Class;
  owl:equivalentClass mls:EvaluationMeasure;
  rdfs:label "EvaluationMeasure";
  rdfs:comment "An evaluation measure used to assess the performance of models trained with log event datasets.".

:ModelEvaluation rdf:type owl:Class;
  owl:equivalentClass mls:ModelEvaluation;
  rdfs:label "ModelEvaluation";
  rdfs:comment "An evaluation of a model trained with a log event dataset.".

:Dataset rdf:type owl:Class;
  rdfs:subClassOf mls:Dataset;
  rdfs:label "Dataset";
  rdfs:comment "A collection of log events.".

:ExampleDataset rdf:type owl:Class;
  rdfs:subClassOf :Dataset;
  rdfs:label "Example Dataset";
  rdfs:comment "A dataset that contains example log events.".

:TestDataset rdf:type owl:Class;
  rdfs:subClassOf :Dataset;
  rdfs:label "Test Dataset";
  rdfs:comment "A dataset that contains test log events.".

:OutputDataset rdf:type owl:Class;
  rdfs:subClassOf :Dataset;
  rdfs:label "Output Dataset";
  rdfs:comment "A dataset that contains output log events.".

:DatasetRow rdf:type owl:Class;
  rdfs:label "DatasetRow";
  rdfs:comment "A row in a log event dataset, representing a single log event.".

#################################################################
#    Object Properties
#################################################################
:hasLabel rdf:type owl:ObjectProperty;
  rdfs:domain :DatasetRow;
  rdfs:range olx:Event;
  rdfs:label "hasLabel";
  rdfs:comment "The label of the log event in a dataset row.".

:hasContext rdf:type owl:ObjectProperty;
  rdfs:domain :DatasetRow;
  rdfs:range olx:Source;
  rdfs:label "hasContext";
  rdfs:comment "The context items associated with a log event in a dataset row.".

:hasPart rdf:type owl:ObjectProperty;
  owl:equivalentProperty mls:hasPart;
  rdfs:label "hasPart";
  rdfs:comment "A part of the dataset, representing a row in the log event dataset.".

:hasInput rdf:type owl:ObjectProperty;
  owl:equivalentProperty mls:hasInput;
  rdfs:label "hasInput";
  rdfs:comment "The input data for the dataset, which can be used to train or evaluate models.".

:hasOutput rdf:type owl:ObjectProperty;
  owl:equivalentProperty mls:hasOutput;
  rdfs:label "hasOutput";
  rdfs:comment "The output data for the dataset, which can be used to train or evaluate models.".

:specifiedBy rdf:type owl:ObjectProperty;
  owl:equivalentProperty mls:specifiedBy;
  rdfs:label "specifiedBy";
  rdfs:comment "The specification of the dataset, which can include details about the data format, structure, and content.".

#################################################################
#    Data properties
#################################################################
:eventMessage rdf:type owl:DatatypeProperty;
  rdfs:domain :DatasetRow;
  rdfs:range xsd:string;
  rdfs:label "Event Message";
  rdfs:comment "The message of the log event in a dataset row.".


