@prefix : <https://cyberseclab.unibs.it/olx/examples/#>.
@prefix olx: <https://cyberseclab.unibs.it/olx/dict#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix time: <http://www.w3.org/2006/time#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

# cloud_share, suricata.log.csv, 20/1/2022 -- 13:16:23 - <Perf> - using shared mpm ctx' for http_stat_msg
:timestamp-2 rdf:type olx:TimeStamp;
  time:inXSDDate "2022-01-20"^^xsd:date;
  time:inXSDDateTimeStamp "2022-01-20T13:16:23Z"^^xsd:dateTimeStamp;
  time:inXSDgYear "2022"^^xsd:gYear;
  time:inXSDgYearMonth "2022-01"^^xsd:gYearMonth.

:source-2 rdf:type olx:Source;
  olx:sourceName "suricata";
  olx:sourceDevice "cloud_share".

:event-2 rdf:type olx:Event;
  olx:hasParameter :timestamp-2;
  olx:wasLoggedBy :source-2.