@base <http://example.com/lkgb/experiments/dictionary>.
@prefix : <http://example.com/lkgb/experiments/dictionary#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

<http://example.com/lkgb/experiments/dictionary> rdf:type owl:Ontology;
  owl:versionIRI <http://example.com/lkgb/experiments/dictionary/1.0.0>;
  <http://purl.org/dc/elements/1.1/creator> "Luca Cotti";
  <http://purl.org/dc/elements/1.1/description> "An ontology to represent experiments.";
  <http://purl.org/dc/elements/1.1/rights> "http://creativecommons.org/licenses/by/4.0/";
  <http://purl.org/dc/elements/1.1/title> "The LKGB experiments ontology.";
  <http://purl.org/vocab/vann/preferredNamespacePrefix> "exp".

#################################################################
#    Annotation properties
#################################################################
###  http://purl.org/dc/elements/1.1/creator
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty.

###  http://purl.org/dc/elements/1.1/description
<http://purl.org/dc/elements/1.1/description> rdf:type owl:AnnotationProperty.

###  http://purl.org/dc/elements/1.1/rights
<http://purl.org/dc/elements/1.1/rights> rdf:type owl:AnnotationProperty.

###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty.

###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty.

#################################################################
#    Classes
#################################################################
:Experiment rdf:type owl:Class;
  rdfs:label "Experiment"@en;
  rdfs:comment "An experiment is a scientific procedure undertaken to make a discovery, test a hypothesis, or demonstrate a known fact."@en.

:Dataset rdf:type owl:Class;
  rdfs:label "Dataset"@en;
  rdfs:comment "A dataset is a collection of data, typically organized in a structured format."@en.

:Example rdf:type owl:Class;
  rdfs:label "Example"@en;
  rdfs:comment "An example is a specific instance or case that illustrates a concept or principle."@en.

:Test rdf:type owl:Class;
  rdfs:label "Test"@en;
  rdfs:comment "A test is a procedure intended to establish the quality, performance, or reliability of something."@en.

#################################################################
#    Relationships
#################################################################
:hasDataset rdf:type owl:ObjectProperty;
  rdfs:domain :Experiment;
  rdfs:range :Dataset;
  rdfs:label "has dataset"@en;
  rdfs:comment "Indicates that an experiment has a specific dataset associated with it."@en.

:hasExample rdf:type owl:ObjectProperty;
  rdfs:domain :Experiment;
  rdfs:range :Example;
  rdfs:label "has example"@en;
  rdfs:comment "Indicates that an experiment has a specific example associated with it."@en.

:hasTest rdf:type owl:ObjectProperty;
  rdfs:domain :Experiment;
  rdfs:range :Test;
  rdfs:label "has test"@en;
  rdfs:comment "Indicates that an experiment has a specific test associated with it."@en.

