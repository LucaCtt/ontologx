@prefix : <https://cyberseclab.unibs.it/olx/examples/#>.
@prefix olx: <https://cyberseclab.unibs.it/olx/dict#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix time: <http://www.w3.org/2006/time#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

# morris_mail, syslog.csv, Jan 25 06:57:57 morris-mail systemd[1993]: Closed GnuPG cryptographic agent (access for web browsers).
:timestamp-7 rdf:type olx:TimeStamp;
  time:inXSDDate "2022-01-25"^^xsd:date;
  time:inXSDDateTimeStamp "2022-01-25T06:57:57Z"^^xsd:dateTimeStamp;
  time:inXSDgYear "2022"^^xsd:gYear;
  time:inXSDgYearMonth "2022-01"^^xsd:gYearMonth.

:system-process-7 rdf:type olx:SystemProcess;
  olx:applicationName "systemd";
  olx:systemProcessPID 1993.

:application-7 rdf:type olx:Application;
  olx:applicationName "GnuPG".

:source-7 rdf:type olx:Source;
  olx:sourceName "syslog";
  olx:sourceDevice "morris-mail".

:event-7 rdf:type olx:Event;
  olx:hasParameter :timestamp-7, :system-process-7, :application-7;
  olx:wasLoggedBy :source-7.