@prefix : <https://cyberseclab.unibs.it/olx/examples/#>.
@prefix olx: <https://cyberseclab.unibs.it/olx/dict#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix time: <http://www.w3.org/2006/time#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

# cloud_share, redis-server.log.1.csv, 5030:signal-handler (1642682292) Received SIGTERM scheduling shutdown...
:system-process-10 rdf:type olx:SystemProcess;
  olx:applicationName "redis";
  olx:systemProcessPID 5030;
  olx:systemProcessSignal "SIGTERM".

:application-10 rdf:type olx:Application;
  olx:applicationName "signal-handler".

:source-10 rdf:type olx:Source;
  olx:sourceName "redis";
  olx:sourceDevice "cloud_share".

:event-10 rdf:type olx:Event;
  olx:hasParameter :timestamp-1, :system-process-10, :application-10;
  olx:wasLoggedBy :source-10.

