@base <https://cyberseclab.unibs.it/olx/dict>.
@prefix olx: <https://cyberseclab.unibs.it/olx/dict#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix time: <http://www.w3.org/2006/time#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix prov: <http://www.w3.org/ns/prov#>.
@prefix p-plan: <http://purl.org/net/p-plan#>.

<https://cyberseclab.unibs.it/olx/dict> rdf:type owl:Ontology;
  owl:versionIRI <https://cyberseclab.unibs.it/olx/dict/1.0.0>;
  <http://purl.org/dc/elements/1.1/creator> "Luca Cotti";
  <http://purl.org/dc/elements/1.1/description> "An ontology to represent log events.";
  <http://purl.org/dc/elements/1.1/rights> "http://creativecommons.org/licenses/by/4.0/";
  <http://purl.org/dc/elements/1.1/title> "The OntoLogX log event ontology.";
  <http://purl.org/dc/elements/1.1/language> "English";
  <http://purl.org/vocab/vann/preferredNamespacePrefix> "olx".

#################################################################
#    Annotation properties
#################################################################
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty.

<http://purl.org/dc/elements/1.1/description> rdf:type owl:AnnotationProperty.
<http://purl.org/dc/elements/1.1/rights> rdf:type owl:AnnotationProperty.
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty.
<http://purl.org/dc/elements/1.1/language> rdf:type owl:AnnotationProperty.
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty.
#################################################################
#    Classes
#################################################################
olx:Event rdf:type owl:Class;
  rdfs:subClassOf prov:Entity;
  rdfs:comment "A single log event, such a log line in a log file.";
  rdfs:label "Event".

olx:Source rdf:type owl:Class;
  rdfs:subClassOf prov:Agent;
  rdfs:comment "A log source, such as an aggregation of logs from different applications (e.g., SysLog) or aggregation of several log files from different devices.";
  rdfs:label "Source".

olx:Parameter rdf:type owl:Class;
  rdfs:subClassOf p-plan:Variable;
  rdfs:comment "A parameter of an Event, such as a command line argument, a URL parameter, etc.";
  rdfs:label "Parameter".

olx:TimeStamp rdf:type owl:Class;
  rdfs:subClassOf time:Instant, olx:Parameter;
  rdfs:comment "A timestamp indicating when an event occurred.";
  rdfs:label "Timestamp".

olx:HashString rdf:type owl:Class;
  rdfs:subClassOf olx:Parameter;
  rdfs:comment "A hash string, such as a file hash, a password hash, etc.";
  rdfs:label "Hash String".

olx:NetworkProtocol rdf:type owl:Class;
  rdfs:subClassOf olx:Parameter;
  rdfs:comment "A network protocol, such as TCP, UDP, etc.";
  rdfs:label "Network Protocol".

olx:NetworkAddress rdf:type owl:Class;
  rdfs:subClassOf olx:Parameter;
  rdfs:comment "A logical address in a network, such as an IP address or a MAC address.";
  rdfs:label "Network Address".

olx:Application rdf:type owl:Class;
  rdfs:subClassOf olx:Parameter, p-plan:Step;
  rdfs:comment "An application, such as a web server, a database, etc.";
  rdfs:label "Application".

olx:SystemProcess rdf:type owl:Class;
  rdfs:subClassOf olx:Application;
  rdfs:comment "An operating system process.";
  rdfs:label "System Process".

olx:ShellCommand rdf:type owl:Class;
  rdfs:subClassOf olx:Application;
  rdfs:comment "A shell command.";
  rdfs:label "Shell Command".

olx:File rdf:type owl:Class;
  rdfs:subClassOf olx:Parameter;
  rdfs:comment "A file, such as a configuration file, a data file, etc.";
  rdfs:label "File".

olx:URL rdf:type owl:Class;
  rdfs:subClassOf olx:Parameter;
  rdfs:comment "A URL, e.g. leading to a web page, a file, etc.";
  rdfs:label "URL".

olx:User rdf:type owl:Class;
  rdfs:subClassOf olx:Parameter;
  rdfs:comment "A user account, such as a local user, a domain user, etc.";
  rdfs:label "User".

olx:UserCredential rdf:type owl:Class;
  rdfs:comment "A credential used by a user to authenticate, such as a username, password, or a token.";
  rdfs:label "Identity Credentials".

olx:UserName rdf:type owl:Class;
  rdfs:subClassOf olx:UserCredential;
  rdfs:comment "A user name, such as a login name.";
  rdfs:label "User Name".

olx:UserEmail rdf:type owl:Class;
  rdfs:subClassOf olx:UserCredential;
  rdfs:comment "An email address, used as a user identifier.";
  rdfs:label "User Email Address".

olx:UserPassword rdf:type owl:Class;
  rdfs:subClassOf olx:UserCredential;
  rdfs:comment "A password, used to authenticate a user.";
  rdfs:label "User Password".

#################################################################
#    Object Properties
#################################################################
olx:hasParameter rdf:type owl:ObjectProperty;
  rdfs:domain olx:Event, olx:Application;
  rdfs:range olx:Parameter;
  rdfs:comment "Relation between an Event or Application and one of its parameter.";
  rdfs:label "Has Parameter".

olx:hasCredential rdf:type owl:ObjectProperty;
  rdfs:domain olx:User;
  rdfs:range olx:UserCredential;
  rdfs:comment "Relation between a User and one of its credentials.";
  rdfs:label "Has Credential".

olx:wasLoggedBy rdf:type owl:ObjectProperty;
  rdfs:subPropertyOf prov:wasAttributedTo;
  rdfs:domain olx:Event;
  rdfs:range olx:Source;
  rdfs:comment "Relation between an Event and the Source that logged it.";
  rdfs:label "Was Logged By".

#################################################################
#    Data properties
#################################################################
olx:eventLogLevel rdf:type owl:DatatypeProperty;
  rdfs:domain olx:Event;
  rdfs:range xsd:string;
  rdfs:comment "Severity of the event, such as INFO, WARNING, ERROR, etc.";
  rdfs:label "Event Severity".

olx:eventID rdf:type owl:DatatypeProperty;
  rdfs:domain olx:Event;
  rdfs:range xsd:string;
  rdfs:comment "Event ID, used to uniquely identify an event.";
  rdfs:label "Event ID".

olx:eventSessionID rdf:type owl:DatatypeProperty;
  rdfs:domain olx:Event;
  rdfs:range xsd:string;
  rdfs:comment "Event session ID, used to group related events together.";
  rdfs:label "Event Session ID".

olx:sourceName rdf:type owl:DatatypeProperty;
  rdfs:domain olx:Source;
  rdfs:range xsd:string;
  rdfs:comment "Name of the log source (e.g. file name, log stream name, etc.)";
  rdfs:label "Source Name".

olx:sourceDevice rdf:type owl:DatatypeProperty;
  rdfs:domain olx:Source;
  rdfs:range xsd:string;
  rdfs:comment "Device name of the log source (e.g. hostname, IP address, etc.)";
  rdfs:label "Source Device".

olx:hashStringAlgorithm rdf:type owl:DatatypeProperty;
  rdfs:domain olx:HashString;
  rdfs:range xsd:string;
  rdfs:comment "File hash algorithm, such as MD5, SHA-1, SHA-256, etc.";
  rdfs:label "Hash String Algorithm".

olx:hashStringValue rdf:type owl:DatatypeProperty;
  rdfs:domain olx:HashString;
  rdfs:range xsd:string;
  rdfs:comment "File hash value";
  rdfs:label "Hash String Value".

olx:networkProtocolName rdf:type owl:DatatypeProperty;
  rdfs:domain olx:NetworkProtocol;
  rdfs:range xsd:string;
  rdfs:comment "Name of the network protocol, such as TCP, UDP, etc.";
  rdfs:label "Network Protocol Name".

olx:networkAddressIPV4 rdf:type owl:DatatypeProperty;
  rdfs:domain olx:NetworkAddress;
  rdfs:range xsd:string;
  rdfs:comment "IPv4 address";
  rdfs:label "IPv4 Address".

olx:networkAddressIPV6 rdf:type owl:DatatypeProperty;
  rdfs:domain olx:NetworkAddress;
  rdfs:range xsd:string;
  rdfs:comment "IPv6 address";
  rdfs:label "IPv6 Address".

olx:networkAddressHostname rdf:type owl:DatatypeProperty;
  rdfs:domain olx:NetworkAddress;
  rdfs:range xsd:string;
  rdfs:comment "Hostname associated with the address";
  rdfs:label "Hostname".

olx:networkAddressMAC rdf:type owl:DatatypeProperty;
  rdfs:domain olx:NetworkAddress;
  rdfs:range xsd:string;
  rdfs:comment "MAC address associated with the address";
  rdfs:label "MAC Address".

olx:networkAddressPort rdf:type owl:DatatypeProperty;
  rdfs:domain olx:NetworkAddress;
  rdfs:range xsd:integer;
  rdfs:comment "Port";
  rdfs:label "Port".

olx:applicationName rdf:type owl:DatatypeProperty;
  rdfs:domain olx:Application;
  rdfs:range xsd:string;
  rdfs:comment "Application name";
  rdfs:label "Application Name".

olx:applicationVersion rdf:type owl:DatatypeProperty;
  rdfs:domain olx:Application;
  rdfs:range xsd:string;
  rdfs:comment "Application version";
  rdfs:label "Application Version".

olx:systemProcessPID rdf:type owl:DatatypeProperty;
  rdfs:domain olx:SystemProcess;
  rdfs:range xsd:integer;
  rdfs:comment "Process ID (pid)";
  rdfs:label "System Process ID".

olx:systemProcessSignal rdf:type owl:DatatypeProperty;
  rdfs:domain olx:SystemProcess;
  rdfs:range xsd:string;
  rdfs:comment "Signal sent to the process";
  rdfs:label "System Process Signal".

olx:filePath rdf:type owl:DatatypeProperty;
  rdfs:domain olx:File;
  rdfs:range xsd:string;
  rdfs:comment "File system path";
  rdfs:label "File Path".

olx:fileLine rdf:type owl:DatatypeProperty;
  rdfs:domain olx:File;
  rdfs:range xsd:integer;
  rdfs:comment "File line number";
  rdfs:label "File Line Number".

olx:urlValue rdf:type owl:DatatypeProperty;
  rdfs:domain olx:URL;
  rdfs:range xsd:string;
  rdfs:comment "URL value";
  rdfs:label "URL Value".

olx:userUID rdf:type owl:DatatypeProperty;
  rdfs:domain olx:User;
  rdfs:range xsd:integer;
  rdfs:comment "User account ID (uid)";
  rdfs:label "User ID".

olx:userAUID rdf:type owl:DatatypeProperty;
  rdfs:domain olx:User;
  rdfs:range xsd:integer;
  rdfs:comment "User account audit ID (auid)";
  rdfs:label "User Audit ID".

olx:userCredentialValue rdf:type owl:DatatypeProperty;
  rdfs:domain olx:UserCredential;
  rdfs:range xsd:string;
  rdfs:comment "Value of the user credential (e.g. username, password, etc.)";
  rdfs:label "User Credential Value".

