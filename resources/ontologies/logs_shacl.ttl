@prefix log: <neo4j://graph.schema#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

log:EventShape rdf:type sh:NodeShape;
  sh:targetClass log:Event;
  sh:closed true;
  sh:property [
    sh:path log:eventMessage;
    sh:datatype xsd:string;
    sh:minCount 1;
    sh:maxCount 1;
  ];
  sh:property [
    sh:path log:eventSeverity;
    sh:datatype xsd:string;
    sh:maxCount 1;
  ];
  sh:property [
    sh:path log:eventID;
    sh:maxCount 1;
  ];
  sh:property [
    sh:path log:eventSessionID;
    sh:datatype xsd:string;
    sh:maxCount 1;
  ];
  sh:property [
    sh:path log:hasParameter;
    # sh:class log:Property;
    sh:nodeKind sh:IRI;
  ].

log:SourceShape rdf:type sh:NodeShape;
  sh:targetClass log:Source;
  sh:closed true;
  sh:or ( [ sh:path log:sourceName ] [ sh:path log:sourceDevice ] );
  sh:property [
    sh:path log:sourceName;
    sh:datatype xsd:string;
    sh:maxCount 1;
  ];
  sh:property [
    sh:path log:sourceDevice;
    sh:datatype xsd:string;
    sh:maxCount 1;
  ].

log:HashStringShape rdf:type sh:NodeShape;
  sh:targetClass log:Hashing;
  sh:closed true;
  sh:property [
    sh:path log:hashStringAlgorithm;
    sh:datatype xsd:string;
    sh:minCount 0;
    sh:maxCount 1;
  ];
  sh:property [
    sh:path log:hashStringValue;
    sh:datatype xsd:string;
    sh:minCount 1;
    sh:maxCount 1;
  ].

log:NetworkProtocolShape rdf:type sh:NodeShape;
  sh:targetClass log:NetworkProtocol;
  sh:closed true;
  sh:property [
    sh:path log:networkProtocolName;
    sh:datatype xsd:string;
    sh:minCount 1;
    sh:maxCount 1;
  ].

log:NetworkAddressShape rdf:type sh:NodeShape;
  sh:targetClass log:NetworkAddress;
  sh:closed true;
  sh:or (
    [ sh:path log:networkAddressIPV4 ]
    [ sh:path log:networkAddressIPV6 ]
    [ sh:path log:networkAddressMAC ]
    [ sh:path log:networkAddressPort ]
    [ sh:path log:networkAddressHostname ]
  );
  sh:property [
    sh:path log:networkAddressIPV4;
    sh:datatype xsd:string;
    sh:maxCount 1;
    sh:pattern "^(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$"^^xsd:string;
  ];
  sh:property [
    sh:path log:networkAddressIPV6;
    sh:datatype xsd:string;
    sh:maxCount 1;
    sh:pattern "^([0-9a-fA-F]{1,4}:){7}[0-9a-fA-F]{1,4}$"^^xsd:string;
  ];
  sh:property [
    sh:path log:networkAddressMAC;
    sh:datatype xsd:string;
    sh:maxCount 1;
    sh:pattern "^([0-9a-fA-F]{2}[:-]){5}([0-9a-fA-F]{2})$"^^xsd:string;
  ];
  sh:property [
    sh:path log:networkAddressPort;
    sh:datatype xsd:integer;
    sh:maxCount 1;
  ];
  sh:property [
    sh:path log:networkAddressHostname;
    sh:datatype xsd:string;
    sh:maxCount 1;
  ].

log:ApplicationShape rdf:type sh:NodeShape;
  sh:targetClass log:Application;
  sh:closed true;
  sh:property [
    sh:path log:applicationName;
    sh:datatype xsd:string;
    sh:maxCount 1;
  ];
  sh:property [
    sh:path log:applicationVersion;
    sh:datatype xsd:string;
    sh:maxCount 1;
  ].

log:SystemProcessShape rdf:type sh:NodeShape;
  sh:targetClass log:SystemProcess;
  sh:closed true;
  sh:or ( [ sh:path log:systemProcessPID ] [ sh:path log:systemProcessSignal ] );
  sh:property [
    sh:path log:systemProcessPID;
    sh:or ( [ sh:datatype xsd:string ] [ sh:datatype xsd:integer ] );
    sh:maxCount 1;
  ];
  sh:property [
    sh:path log:systemProcessSignal;
    sh:datatype xsd:string;
    sh:maxCount 1;
  ].

log:FileShape rdf:type sh:NodeShape;
  sh:targetClass log:File;
  sh:closed true;
  sh:property [
    sh:path log:filePath;
    sh:datatype xsd:string;
    sh:minCount 1;
    sh:maxCount 1;
  ];
  sh:property [
    sh:path log:fileLine;
    sh:datatype xsd:integer;
    sh:maxCount 1;
  ].

log:URLShape rdf:type sh:NodeShape;
  sh:targetClass log:URL;
  sh:closed true;
  sh:property [
    sh:path log:urlValue;
    sh:datatype xsd:string;
    sh:minCount 1;
    sh:maxCount 1;
  ].

log:UserShape rdf:type sh:NodeShape;
  sh:targetClass log:User;
  sh:closed true;
  sh:or (
    [ sh:path log:userUID ]
    [ sh:path log:userAUID ]
  );
  sh:property [
    sh:path log:userUID;
    sh:or ( [ sh:datatype xsd:string ] [ sh:datatype xsd:integer ] );
    sh:maxCount 1;
  ];
  sh:property [
    sh:path log:userAUID;
    sh:or ( [ sh:datatype xsd:string ] [ sh:datatype xsd:integer ] );
    sh:maxCount 1;
  ];
  sh:property [
    sh:path log:hasCredential;
    # sh:class log:IdentityCredential;
    sh:nodeKind sh:IRI;
  ].

log:UserCredentialShape rdf:type sh:NodeShape;
  sh:targetClass log:UserCredential;
  sh:closed true;
  sh:property [
    sh:path log:userCredentialValue;
    sh:datatype xsd:string;
    sh:minCount 1;
    sh:maxCount 1;
  ].

